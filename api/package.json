{
  "name": "portfolio-api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 3000 --ip 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "deploy": "tsc --noEmit && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply portfolio --local",
    "db:migrate:remote": "wrangler d1 migrations apply portfolio --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.16.0"
  }
}
